# UID do usuario para evitar arquivos root nos volumes montados.
# No Windows/WSL2 o valor 50000 corresponde ao usuario airflow da imagem oficial.
AIRFLOW_UID=50000

# Credenciais do Postgres de metadados do Airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# Credenciais do Postgres de dados (camadas raw/trusted/refined)
WAREHOUSE_DB_USER=datarisk
WAREHOUSE_DB_PASSWORD=datarisk
WAREHOUSE_DB_NAME=nyc_taxi

# Usuario admin da UI do Airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
